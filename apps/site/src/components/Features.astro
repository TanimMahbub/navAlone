---
// Crisp Feather/Lucide-style inline SVG icons (stroke, currentColor) — no emoji.
const ICONS: Record<string, string> = {
    layers:
        '<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>',
    layout:
        '<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>',
    droplet:
        '<path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>',
    package:
        '<line x1="16.5" y1="9.4" x2="7.5" y2="4.21"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>',
    accessibility:
        '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="8" r="2.1"/><path d="M7 18a5 5 0 0 1 10 0"/>',
    terminal:
        '<polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>'
};

const features = [
    {
        icon: "layers",
        title: "One model, every screen",
        body: "A single items array drives the desktop bar and the off-canvas mobile drawer — one nav, no duplicated markup to keep in sync."
    },
    {
        icon: "layout",
        title: "Every submenu style",
        body: "Dropdowns, large dropdowns, arbitrarily nested flyouts and column mega menus — pick a display per submenu."
    },
    {
        icon: "droplet",
        title: "Themeable with --nv-* tokens",
        body: "Restyle everything through CSS custom properties or a theme object. Try the live playground in the docs."
    },
    {
        icon: "package",
        title: "React, Vue & Angular wrappers",
        body: "Thin, SSR-safe, tree-shakeable adapters over the same vanilla core. Framework deps stay as peerDependencies."
    },
    {
        icon: "accessibility",
        title: "Accessible by default",
        body: "Roving focus, keyboard navigation, a modal drawer with scroll-lock, and ARIA wiring out of the box."
    },
    {
        icon: "terminal",
        title: "Build-free or bundled",
        body: "Drop in a <script> tag from a CDN, or import the typed ESM/CJS build into your toolchain."
    }
];

const compare = [
    { task: "Desktop navigation", byHand: "Build a horizontal bar with hover/click dropdowns", navalone: "Included" },
    { task: "Mobile navigation", byHand: "Build a separate hamburger + off-canvas drawer", navalone: "The same instance, automatically" },
    { task: "Dropdowns & mega menus", byHand: "Hand-roll open/close, positioning and focus", navalone: "A declarative display per submenu" },
    { task: "Multi-level menus", byHand: "Track nested open state yourself", navalone: "Arbitrary depth, built in" },
    { task: "Keeping it in sync", byHand: "Two markup trees to maintain", navalone: "One data model" },
    { task: "Accessibility", byHand: "Wire ARIA, roving focus and scroll-lock", navalone: "Out of the box" }
];
---

<section id="features">
    <div class="wrap">
        <div class="section-head">
            <p class="eyebrow">Why Navalone</p>
            <h2>One nav is all you ship.</h2>
            <p>Stop maintaining a desktop menu and a separate mobile menu. Navalone drives every
            layer — dropdowns, mega menus, nested flyouts and the mobile drawer — from a single
            model.</p>
        </div>

        <div class="feature-grid">
            {
                features.map((f) => (
                    <article class="feature reveal">
                        <div class="feature-icon" aria-hidden="true">
                            <svg
                                viewBox="0 0 24 24"
                                width="22"
                                height="22"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.8"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                set:html={ICONS[f.icon]}
                            />
                        </div>
                        <h3>{f.title}</h3>
                        <p>{f.body}</p>
                    </article>
                ))
            }
        </div>

        <div class="compare reveal">
            <table>
                <thead>
                    <tr>
                        <th>What you'd juggle</th>
                        <th>Doing it by hand</th>
                        <th class="col-nv">With Navalone</th>
                    </tr>
                </thead>
                <tbody>
                    {
                        compare.map((row) => (
                            <tr>
                                <td>{row.task}</td>
                                <td>{row.byHand}</td>
                                <td class="col-nv">✓ {row.navalone}</td>
                            </tr>
                        ))
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

<style>
    .feature-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }
    .feature {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 26px;
    }
    .feature-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        margin-bottom: 16px;
        border-radius: 12px;
        background: rgba(128, 203, 196, 0.12);
        border: 1px solid rgba(128, 203, 196, 0.25);
        color: var(--accent);
    }
    .feature h3 {
        margin: 0 0 8px;
        font-size: 1.15rem;
        color: var(--title);
    }
    .feature p {
        margin: 0;
        color: var(--text);
        font-size: 0.95rem;
    }
    .compare {
        margin-top: 56px;
        overflow-x: auto;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 14px;
    }
    table {
        width: 100%;
        border-collapse: collapse;
    }
    th,
    td {
        text-align: left;
        padding: 14px 18px;
        border-bottom: 1px solid var(--border);
        font-size: 0.95rem;
    }
    thead th {
        background: var(--bg-2);
        color: var(--title);
    }
    td {
        color: var(--text);
    }
    td:first-child {
        color: var(--title);
    }
    tbody tr {
        transition: background 0.15s ease;
    }
    tbody tr:hover {
        background: rgba(128, 203, 196, 0.05);
    }
    .col-nv {
        color: var(--accent-2);
        background: rgba(128, 203, 196, 0.07);
    }
    tbody tr:last-child td {
        border-bottom: none;
    }
    @media (max-width: 860px) {
        .feature-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
