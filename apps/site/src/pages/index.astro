---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Features from "../components/Features.astro";
import CodeShowcase from "../components/CodeShowcase.astro";
import HtmlStructure from "../components/HtmlStructure.astro";
import CTA from "../components/CTA.astro";
---

<Layout>
    <Hero />
    <Features />
    <CodeShowcase />
    <HtmlStructure />
    <CTA />
</Layout>

<script>
    // Scroll-reveal for `.reveal` blocks — a tiny IntersectionObserver, no library.
    // The hidden start state is gated behind `.reveal-ready` (added synchronously in
    // <head> only when motion is allowed), so no-JS / reduced-motion shows everything.
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const blocks = Array.from(document.querySelectorAll<HTMLElement>(".reveal"));
    if (!reduce && "IntersectionObserver" in window) {
        const io = new IntersectionObserver(
            (entries, obs) => {
                for (const entry of entries) {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("is-visible");
                        obs.unobserve(entry.target);
                    }
                }
            },
            { rootMargin: "0px 0px -15% 0px" }
        );
        blocks.forEach((el) => io.observe(el));
    } else {
        blocks.forEach((el) => el.classList.add("is-visible"));
    }
</script>
