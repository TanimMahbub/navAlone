{
    "name": "navalone-monorepo",
    "version": "0.0.0",
    "private": true,
    "description": "Monorepo for Navalone — a free, open-source responsive main-menu plugin (alternative to mmenu.js).",
    "author": "Tanim Mahbub",
    "license": "MIT",
    "type": "module",
    "packageManager": "pnpm@9.15.9",
    "scripts": {
        "build": "pnpm -r run build",
        "dev": "pnpm --filter navalone run dev",
        "test": "pnpm -r run test",
        "test:e2e": "pnpm --filter navalone run test:e2e",
        "example": "pnpm --filter navalone run example",
        "lint": "eslint .",
        "format": "prettier --write ."
    },
    "devDependencies": {
        "@eslint/js": "^9.17.0",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^9.1.0",
        "prettier": "^3.4.2",
        "typescript": "^5.7.2",
        "typescript-eslint": "^8.18.1"
    }
}
