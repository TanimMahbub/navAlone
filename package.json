{
    "name": "navalone-monorepo",
    "version": "0.0.0",
    "private": true,
    "description": "Monorepo for Navalone — a free, open-source responsive main-menu plugin (alternative to mmenu.js).",
    "author": "Tanim Mahbub",
    "license": "MIT",
    "type": "module",
    "packageManager": "pnpm@9.15.9",
    "scripts": {
        "build": "pnpm -r run build",
        "build:core": "pnpm --filter navalone run build",
        "build:packages": "pnpm --filter \"./packages/*\" run build",
        "build:apps": "pnpm --filter \"./apps/*\" run build",
        "dev": "pnpm --filter navalone run dev",
        "dev:docs": "pnpm --filter @navalone/docs run dev",
        "dev:site": "pnpm --filter @navalone/site run dev",
        "preview:docs": "pnpm --filter @navalone/docs run preview",
        "preview:site": "pnpm --filter @navalone/site run preview",
        "test": "pnpm -r run test",
        "test:e2e": "pnpm --filter navalone run test:e2e",
        "typecheck": "pnpm -r run typecheck",
        "example:core": "pnpm --filter navalone run example",
        "example:react": "pnpm --filter @navalone/react run example",
        "example:vue": "pnpm --filter @navalone/vue run example",
        "example:angular": "pnpm --filter @navalone/angular run example",
        "lint": "eslint .",
        "format": "prettier --write ."
    },
    "devDependencies": {
        "@eslint/js": "^9.17.0",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^9.1.0",
        "prettier": "^3.4.2",
        "typescript": "^5.7.2",
        "typescript-eslint": "^8.18.1"
    },
    "pnpm": {
        "overrides": {
            "typescript": "5.8.3"
        }
    }
}
