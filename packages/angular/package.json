{
    "name": "@navalone/angular",
    "version": "0.0.0",
    "description": "Angular wrapper for Navalone — a free, open-source responsive main-menu plugin. A thin standalone component over the framework-agnostic core.",
    "keywords": [
        "navalone",
        "angular",
        "menu",
        "navigation",
        "navbar",
        "mega-menu",
        "mobile-menu",
        "off-canvas",
        "drawer",
        "responsive"
    ],
    "author": "Tanim Mahbub",
    "license": "MIT",
    "scripts": {
        "build": "ng-packagr -p ng-package.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "example": "vite example",
        "example:build": "vite build example"
    },
    "peerDependencies": {
        "@angular/common": "^18.0.0 || ^19.0.0",
        "@angular/core": "^18.0.0 || ^19.0.0",
        "navalone": "workspace:^"
    },
    "devDependencies": {
        "@analogjs/vite-plugin-angular": "^1.10.0",
        "@analogjs/vitest-angular": "^1.10.0",
        "@angular/common": "^19.2.0",
        "@angular/compiler": "^19.2.0",
        "@angular/compiler-cli": "^19.2.0",
        "@angular/core": "^19.2.0",
        "@angular/platform-browser": "^19.2.0",
        "@angular/platform-browser-dynamic": "^19.2.0",
        "jsdom": "^25.0.1",
        "navalone": "workspace:*",
        "ng-packagr": "^19.2.0",
        "rxjs": "^7.8.1",
        "tslib": "^2.8.1",
        "typescript": "^5.7.2",
        "vite": "^6.0.0",
        "vitest": "^2.1.8",
        "zone.js": "^0.15.0"
    }
}
