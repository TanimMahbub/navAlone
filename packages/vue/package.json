{
    "name": "@navalone/vue",
    "version": "0.0.0",
    "description": "Vue 3 wrapper for Navalone — a free, open-source responsive main-menu plugin. A thin adapter over the framework-agnostic core.",
    "keywords": [
        "navalone",
        "vue",
        "vue3",
        "menu",
        "navigation",
        "navbar",
        "mega-menu",
        "mobile-menu",
        "off-canvas",
        "drawer",
        "responsive"
    ],
    "author": "Tanim Mahbub",
    "license": "MIT",
    "homepage": "https://github.com/TanimMahbub/navAlone#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/TanimMahbub/navAlone.git",
        "directory": "packages/vue"
    },
    "bugs": {
        "url": "https://github.com/TanimMahbub/navAlone/issues"
    },
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "src",
        "README.md"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "vue-tsc --noEmit",
        "example": "vite example",
        "example:build": "vite build example"
    },
    "peerDependencies": {
        "navalone": "workspace:^",
        "vue": "^3.4.0"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^5.2.1",
        "@vue/test-utils": "^2.4.6",
        "jsdom": "^25.0.1",
        "navalone": "workspace:*",
        "tsup": "^8.3.5",
        "typescript": "^5.7.2",
        "vite": "^6.0.0",
        "vitest": "^2.1.8",
        "vue": "^3.5.13",
        "vue-tsc": "^2.1.10"
    }
}
