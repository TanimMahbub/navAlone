{
    "tabWidth": 4,
    "useTabs": false,
    "semi": true,
    "singleQuote": false,
    "printWidth": 100,
    "trailingComma": "none",
    "overrides": [
        {
            "files": "*.css",
            "options": { "useTabs": true }
        },
        {
            "files": ["*.json", "*.yml", "*.yaml"],
            "options": { "tabWidth": 2 }
        }
    ]
}
